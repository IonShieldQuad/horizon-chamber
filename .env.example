# ──────────────────────────────────────────────────────────────────────────
# Horizon Chamber — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# DeepSeek API key (required for Chaos Tamer & AI features)
# Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# SQLite database path (default: ./horizon.db)
# DATABASE_PATH=./horizon.db

# ── Activity Tracking ────────────────────────────────────────────────────
# Start activity monitor on server boot (true/false)
# AUTO_START_MONITOR=false

# Seconds between activity checks (default: 3)
# ACTIVITY_POLL_INTERVAL=3

# Seconds idle before marking "away" (default: 60)
# ACTIVITY_IDLE_THRESHOLD=60

# Auto-delete activity logs older than N days (default: 30)
# ACTIVITY_PRUNE_DAYS=30

# ── Feed / n8n Integration ───────────────────────────────────────────────
# n8n webhook URL to trigger fetching
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/your-webhook-id

# Optional API key sent to n8n webhook
# N8N_API_KEY=

# API key to validate n8n→Horizon ingest requests (empty = no auth in dev)
# FEED_API_KEY=

# Hours between automatic scheduled fetches (default: 6)
# FEED_POLL_INTERVAL_HOURS=6

# Auto-fetch on startup if last fetch is older than interval (default: true)
# FEED_AUTO_FETCH=true

# Seconds between scheduler loop checks (default: 60)
# FEED_SCHEDULER_INTERVAL=60

# ── Feature Flags ────────────────────────────────────────────────────────
# Enable active window tracking (default: true)
# FEATURE_ACTIVE_WINDOW=true

# Enable idle time tracking (default: true)
# FEATURE_IDLE_TIME=true

# Enable process tree tracking (heavier, off by default)
# FEATURE_PROCESS_LIST=false

# ── Goal Engine ──────────────────────────────────────────────────────────
# Days without activity before a reminder is sent (default: 3)
# GOAL_REMINDER_GAP_DAYS=3

# Maximum tasks to carry over per day (default: 3)
# GOAL_MAX_CARRY_OVER=3

# Generate tasks automatically on server open (default: true)
# GOAL_GENERATE_ON_OPEN=true

# Enable nudge suggestions (default: true)
# NUDGES_ENABLED=true
